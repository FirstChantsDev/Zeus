{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "echo 'cockpit-server is plain Node - no build step'"
  },
  "deploy": {
    "startCommand": "node deploy/cockpit-server/server.js",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
