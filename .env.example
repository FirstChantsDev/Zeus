# Copy this file to .env at the repo root and fill in the values.
# .env is gitignored — never commit the real one.

# The agent's brain — one API call per spoken sentence + meeting summaries.
ANTHROPIC_API_KEY=

# Phase 10: the Outlook calendar (read-only), from your Entra app registration.
# Where to get these: NOTES.md → "Outlook calendar (Microsoft Graph) — setup".
# MS_CLIENT_ID     = Entra portal → your app → Overview → "Application (client) ID"
# MS_CLIENT_SECRET = Entra portal → your app → Certificates & secrets → the secret's VALUE
# (MICROSOFT_CLIENT_ID / MICROSOFT_CLIENT_SECRET work too — both spellings accepted)
MS_CLIENT_ID=
MS_CLIENT_SECRET=

# Only needed if the cockpit is not on http://localhost:4300
# MS_REDIRECT_URI=http://localhost:4300/auth/callback
